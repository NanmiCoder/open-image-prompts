{
  "name": "open-image-prompts-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "node scripts/with_api.mjs dev",
    "dev:web": "vite",
    "api": "node ../scripts/run_python.mjs ../server/oip_api.py",
    "test": "npm run test:search && npm run test:gallery",
    "test:search": "node --test scripts/test_search_state.mjs",
    "test:gallery": "node --test scripts/test_gallery_session.mjs",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "node scripts/with_api.mjs preview"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@tailwindcss/vite": "^4.2.1",
    "framer-motion": "^12.35.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "^7.3.1"
  }
}
